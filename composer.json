{
    "name": "ebocify/backend",
    "type": "project",
    "description": "Export Document Management Platform - Laravel Backend",
    "keywords": ["export", "documents", "commerce", "invoice", "laravel"],
    "license": "MIT",
    "require": {
        "php": "^8.1",
        "laravel/framework": "^10.0",
        "laravel/sanctum": "^3.0",
        "laravel/tinker": "^2.8",
        "laravel/socialite": "^5.0",
        "stripe/stripe-php": "^13.0",
        "barryvdh/laravel-dompdf": "^2.0",
        "openai-php/laravel": "^0.8",
        "spatie/laravel-activitylog": "^4.0",
        "spatie/laravel-backup": "^8.0",
        "maatwebsite/excel": "^3.0",
        "league/flysystem-aws-s3-v3": "^3.0",
        "guzzlehttp/guzzle": "^7.2"
    },
    "require-dev": {
        "fakerphp/faker": "^1.9.1",
        "laravel/pint": "^1.0",
        "laravel/sail": "^1.18",
        "mockery/mockery": "^1.4.4",
        "phpunit/phpunit": "^10.1",
        "spatie/laravel-debugbar": "^3.8"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover --ansi"
        ],
        "post-update-cmd": [
            "@php artisan vendor:publish --tag=laravel-assets --ansi --force"
        ],
        "post-root-package-install": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ],
        "post-create-project-cmd": [
            "@php artisan key:generate --ansi"
        ]
    },
    "extra": {
        "laravel": {
            "dont-discover": []
        }
    },
    "config": {
        "sort-packages": true,
        "optimize-autoloader": true,
        "allow-plugins": {
            "pestphp/pest-plugin-laravel": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
